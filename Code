// ── Entry point ────────────────────────────────────────────
function doGet(e) {
  const page = e && e.parameter && e.parameter.page ? e.parameter.page : 'index';
  const template = HtmlService.createTemplateFromFile('index');
  template.page = page;
  const html = template.evaluate()
    .setTitle('Capítulo ICESI — ANEIAP')
    .setFaviconUrl('https://raw.githubusercontent.com/tu-usuario/icesi-web/main/assets/favicon.png')
    .addMetaTag('viewport', 'width=device-width, initial-scale=1')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
  return html;
}

// ── Include helper ─────────────────────────────────────────
function include(filename) {
  return HtmlService.createHtmlOutputFromFile(filename).getContent();
}

// ── Obtener spreadsheet ────────────────────────────────────
function getSpreadsheet() {
  return SpreadsheetApp.openById(SHEET_ID);
}

function getSheet(name) {
  const ss = getSpreadsheet();
  let sheet = ss.getSheetByName(name);
  if (!sheet) {
    // Crear la hoja si no existe
    sheet = ss.insertSheet(name);
  }
  return sheet;
}

// ── Leer datos genérico ────────────────────────────────────
function sheetToJSON(sheetName) {
  try {
    const sheet = getSheet(sheetName);
    const data = sheet.getDataRange().getValues();
    if (data.length < 2) return [];
    const headers = data[0].map(h => h.toString().trim().toLowerCase().replace(/\s+/g, '_'));
    return data.slice(1)
      .filter(row => row.some(cell => cell !== ''))
      .map(row => {
        const obj = {};
        headers.forEach((h, i) => { obj[h] = row[i] !== undefined ? row[i].toString() : ''; });
        return obj;
      });
  } catch(e) {
    Logger.log('Error en sheetToJSON(' + sheetName + '): ' + e);
    return [];
  }
}

// ── Config del sitio ───────────────────────────────────────
function getConfig() {
  try {
    const sheet = getSheet(SHEETS.CONFIG);
    const data = sheet.getDataRange().getValues();
    const config = {};
    data.forEach(row => {
      if (row[0]) config[row[0].toString().trim().toLowerCase().replace(/\s+/g, '_')] = row[1] ? row[1].toString() : '';
    });
    return config;
  } catch(e) {
    return {};
  }
}

