// ── Menú personalizado en el Sheet ────────────────────────
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('🦅 ICESI Web')
    .addItem('⚙️ Configurar hojas', 'setupSheets')
    .addItem('🌐 Abrir sitio web', 'openWebsite')
    .addSeparator()
    .addItem('📋 Ver instrucciones', 'showInstructions')
    .addToUi();
}

function openWebsite() {
  const url = ScriptApp.getService().getUrl();
  const html = HtmlService.createHtmlOutput(
    `<script>window.open('${url}','_blank');google.script.host.close();</script>`
  );
  SpreadsheetApp.getUi().showModalDialog(html, 'Abriendo sitio...');
}

